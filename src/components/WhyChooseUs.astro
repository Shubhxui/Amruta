---
import { site } from "../data/site";
import Icon from "./Icon.astro";
import { asset } from "../lib/asset";
---

<section id="why" class="why">
  <div class="container-page why__inner">
    <div class="why__media reveal">
      <div class="why__frame">
        <img
          src={asset("images/care-1.jpg")}
          alt="A doctor performing an ultrasound scan for an expecting mother"
          width="1000"
          height="760"
          loading="lazy"
          decoding="async"
        />
      </div>
      <div class="why__quote">
        <span class="why__quote-icon"><Icon name="chat" class="w-5 h-5" /></span>
        <p>Have a question? Our care team replies on WhatsApp, every day.</p>
        <a href={site.contact.phoneHref} class="btn btn-primary why__quote-btn">Chat now</a>
      </div>
    </div>

    <div class="why__copy">
      <span class="eyebrow reveal">Why families choose us</span>
      <h2 class="why__title h-section reveal" data-delay="60">Expert care that feels personal, never rushed</h2>
      <p class="why__text lead reveal" data-delay="120">
        Choosing where to welcome your baby matters. Here's why thousands of Pune
        families trust Amruta with the moments that matter most.
      </p>

      <div class="why__features">
        {site.whyUs.map((f, i) => (
          <article class="why__feature reveal" data-delay={i * 70}>
            <span class="why__feature-icon"><Icon name={f.icon} class="w-5 h-5" /></span>
            <div>
              <h3 class="why__feature-title">{f.title}</h3>
              <p class="why__feature-text">{f.text}</p>
            </div>
          </article>
        ))}
      </div>
    </div>
  </div>
</section>

<style>
  .why { padding-block: clamp(4rem, 8vw, 6.5rem); background: var(--color-cream-soft); }
  .why__inner { display: grid; gap: clamp(2.5rem, 5vw, 4rem); align-items: center; }

  .why__media { position: relative; }
  .why__frame { border-radius: var(--radius-2xl); overflow: hidden; aspect-ratio: 4 / 3.4; background: var(--color-cream); }
  .why__frame img { width: 100%; height: 100%; object-fit: cover; }
  .why__quote {
    position: absolute; right: 1rem; bottom: -1.25rem; left: 1rem;
    background: #fff; border: 1px solid var(--color-line);
    border-radius: var(--radius-lg); padding: 1.1rem 1.25rem;
    display: flex; align-items: center; gap: 0.85rem;
    box-shadow: 0 22px 48px -28px rgba(14,14,14,0.4);
  }
  .why__quote-icon { flex: none; display: inline-flex; align-items: center; justify-content: center; width: 40px; height: 40px; border-radius: 999px; background: var(--color-cream); color: var(--color-ink); }
  .why__quote p { font-size: 0.9rem; color: var(--color-ink); line-height: 1.4; flex: 1; }
  .why__quote-btn { padding: 0.65rem 1.1rem; font-size: 0.85rem; }

  .why__title { margin-top: 1rem; }
  .why__text { margin-top: 1.1rem; max-width: 32rem; }
  .why__features { margin-top: 2rem; display: grid; grid-template-columns: 1fr; gap: 1.4rem; }
  .why__feature { display: flex; gap: 1rem; }
  .why__feature-icon {
    flex: none; display: inline-flex; align-items: center; justify-content: center;
    width: 46px; height: 46px; border-radius: 999px;
    background: var(--color-accent); color: var(--color-ink);
  }
  .why__feature-title { font-size: 1.08rem; font-weight: 600; }
  .why__feature-text { margin-top: 0.3rem; color: var(--color-ink-soft); font-size: 0.92rem; line-height: 1.55; }

  @media (min-width: 600px) { .why__features { grid-template-columns: 1fr 1fr; gap: 1.75rem; } }
  @media (min-width: 960px) { .why__inner { grid-template-columns: 1fr 1.05fr; gap: 4rem; } }
</style>
