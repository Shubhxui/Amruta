---
import { site } from "../data/site";
import Icon from "./Icon.astro";
import { asset } from "../lib/asset";
---

<section id="doctors" class="doctors">
  <div class="container-page">
    <div class="section-head reveal">
      <span class="eyebrow">Meet our specialists</span>
      <h2 class="section-title h-section">The caring team behind every safe delivery</h2>
      <p class="section-sub lead">
        Experienced, friendly and always approachable — our doctors guide you with
        expertise and warmth.
      </p>
    </div>

    <div class="doctors__grid">
      {site.doctors.map((doc, i) => (
        <article class="doctors__card reveal" data-delay={i * 60}>
          <div class="doctors__photo">
            <img
              src={asset(doc.image)}
              alt={`${doc.name}, ${doc.role} at Amruta Maternity Hospital`}
              width="600"
              height="720"
              loading="lazy"
              decoding="async"
            />
            <div class="doctors__socials">
              <a href="#contact" aria-label={`Book with ${doc.name}`}><Icon name="calendar" class="w-[18px] h-[18px]" /></a>
              <a href={site.contact.phoneHref} aria-label={`Call about ${doc.name}`}><Icon name="phone" class="w-[18px] h-[18px]" /></a>
            </div>
          </div>
          <div class="doctors__body">
            <h3 class="doctors__name">{doc.name}</h3>
            <p class="doctors__role">{doc.role}</p>
            <p class="doctors__detail">{doc.detail}</p>
          </div>
        </article>
      ))}
    </div>
  </div>
</section>

<style>
  .doctors { padding-block: clamp(4rem, 8vw, 6.5rem); background: var(--color-paper); }
  .section-head { max-width: 42rem; margin: 0 auto clamp(2.5rem, 5vw, 3.5rem); text-align: center; }
  .section-head .eyebrow { justify-content: center; }
  .section-title { margin-top: 1rem; }
  .section-sub { margin-top: 1rem; }

  .doctors__grid { display: grid; grid-template-columns: 1fr; gap: 1.25rem; }
  .doctors__card {
    background: #fff; border: 1px solid var(--color-line);
    border-radius: var(--radius-xl); overflow: hidden;
    transition: transform 0.25s, box-shadow 0.25s;
  }
  .doctors__card:hover { transform: translateY(-5px); box-shadow: 0 26px 52px -32px rgba(14,14,14,0.42); }
  .doctors__photo { position: relative; aspect-ratio: 4 / 4.4; overflow: hidden; background: var(--color-cream); }
  .doctors__photo img { width: 100%; height: 100%; object-fit: cover; object-position: center 22%; }
  .doctors__socials {
    position: absolute; right: 12px; bottom: 12px;
    display: flex; flex-direction: column; gap: 0.45rem;
    opacity: 0; transform: translateY(8px); transition: opacity 0.25s, transform 0.25s;
  }
  .doctors__card:hover .doctors__socials { opacity: 1; transform: none; }
  .doctors__socials a {
    display: inline-flex; align-items: center; justify-content: center;
    width: 38px; height: 38px; border-radius: 999px;
    background: #fff; color: var(--color-ink);
    box-shadow: 0 8px 18px -8px rgba(14,14,14,0.5);
    transition: background 0.2s, color 0.2s;
  }
  .doctors__socials a:hover { background: var(--color-accent); }

  .doctors__body { padding: 1.3rem 1.3rem 1.5rem; }
  .doctors__name { font-size: 1.12rem; font-weight: 600; }
  .doctors__role { margin-top: 0.3rem; font-weight: 500; font-size: 0.88rem; color: var(--color-ink); }
  .doctors__detail { margin-top: 0.4rem; color: var(--color-ink-soft); font-size: 0.83rem; }

  @media (min-width: 560px) { .doctors__grid { grid-template-columns: 1fr 1fr; } }
  @media (min-width: 1000px) { .doctors__grid { grid-template-columns: repeat(4, 1fr); } }
</style>
