---
import { site } from "../data/site";
---

<section id="journey" class="journey">
  <div class="container-page">
    <div class="journey__head">
      <div class="reveal">
        <span class="eyebrow eyebrow--light">How our care works</span>
        <h2 class="journey__title h-section">Supported at every step, from start to cradle</h2>
      </div>
      <p class="journey__intro reveal" data-delay="80">
        We make every stage feel clear and calm — here's how we care for you and
        your baby, from the very first visit to your newborn's homecoming.
      </p>
    </div>

    <div class="journey__grid">
      {site.journey.map((stage, i) => (
        <article class="journey__step reveal" data-delay={i * 80}>
          <span class="journey__num">{stage.step}</span>
          <h3 class="journey__step-title">{stage.title}</h3>
          <p class="journey__step-text">{stage.text}</p>
        </article>
      ))}
    </div>
  </div>
</section>

<style>
  .journey {
    padding-block: clamp(4rem, 8vw, 6.5rem);
    background: var(--color-dark);
    color: #fff;
  }
  .journey__head {
    display: grid;
    gap: 1.25rem;
    align-items: end;
    margin-bottom: clamp(2.5rem, 5vw, 3.5rem);
  }
  .journey__title { color: #fff; margin-top: 1rem; }
  .journey__intro { color: rgba(255,255,255,0.62); line-height: 1.65; max-width: 30rem; }

  .journey__grid {
    display: grid;
    grid-template-columns: 1fr;
    gap: 2rem 1.5rem;
  }
  .journey__step { padding-top: 1.6rem; border-top: 1px solid var(--color-dark-line); }
  .journey__num {
    display: block;
    font-size: 2.6rem;
    font-weight: 600;
    letter-spacing: -0.03em;
    color: var(--color-accent);
    line-height: 1;
  }
  .journey__step-title { color: #fff; font-size: 1.2rem; font-weight: 600; margin-top: 1.1rem; }
  .journey__step-text { margin-top: 0.6rem; color: rgba(255,255,255,0.6); line-height: 1.6; font-size: 0.94rem; }

  @media (min-width: 720px) { .journey__grid { grid-template-columns: 1fr 1fr; } }
  @media (min-width: 1000px) {
    .journey__head { grid-template-columns: 1.4fr 1fr; }
    .journey__grid { grid-template-columns: repeat(4, 1fr); }
  }
</style>
