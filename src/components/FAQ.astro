---
import { site } from "../data/site";
import Icon from "./Icon.astro";
---

<section id="faq" class="faq">
  <div class="container-page faq__inner">
    <div class="faq__intro">
      <span class="eyebrow reveal"><Icon name="chat" class="w-4 h-4" /> Good to know</span>
      <h2 class="faq__title reveal" data-delay="60">Questions expecting parents often ask</h2>
      <p class="faq__text reveal" data-delay="120">
        Can't find what you're looking for? Our friendly front desk is always
        happy to help — just call or message us.
      </p>
      <a href={site.contact.phoneHref} class="btn btn-primary reveal" data-delay="160">
        <Icon name="phone" class="w-[18px] h-[18px]" /> {site.contact.phone}
      </a>
    </div>

    <div class="faq__list">
      {site.faq.map((item, i) => (
        <details class="faq__item reveal" data-delay={i * 60} name="faq" open={i === 0}>
          <summary class="faq__q">
            <span>{item.q}</span>
            <span class="faq__toggle" aria-hidden="true">
              <Icon name="plus" class="w-5 h-5 faq__plus" strokeWidth={2} />
              <Icon name="minus" class="w-5 h-5 faq__minus" strokeWidth={2} />
            </span>
          </summary>
          <div class="faq__a"><p>{item.a}</p></div>
        </details>
      ))}
    </div>
  </div>
</section>

<style>
  .faq { padding-block: 5rem; }
  .faq__inner {
    display: grid;
    gap: 2.5rem;
    align-items: start;
  }
  .faq__title { font-size: clamp(2rem, 4vw, 2.7rem); margin-top: 1.1rem; }
  .faq__text { margin-top: 1rem; color: var(--color-ink-soft); line-height: 1.7; max-width: 28rem; }
  .faq__intro .btn { margin-top: 1.6rem; }

  .faq__list { display: flex; flex-direction: column; gap: 0.85rem; }
  .faq__item {
    background: #fff;
    border: 1px solid var(--color-cream-300);
    border-radius: var(--radius-xl);
    padding: 0.4rem 1.4rem;
    transition: border-color 0.25s, box-shadow 0.25s;
  }
  .faq__item[open] {
    border-color: var(--color-brand-200);
    box-shadow: 0 18px 40px -28px rgba(133, 56, 66, 0.35);
  }
  .faq__q {
    display: flex;
    align-items: center;
    justify-content: space-between;
    gap: 1rem;
    padding: 1.05rem 0;
    cursor: pointer;
    font-weight: 600;
    font-size: 1.04rem;
    color: var(--color-ink);
    list-style: none;
  }
  .faq__q::-webkit-details-marker { display: none; }
  .faq__toggle {
    flex: none;
    display: inline-flex;
    align-items: center;
    justify-content: center;
    width: 34px; height: 34px;
    border-radius: 50%;
    background: var(--color-brand-50);
    color: var(--color-brand-600);
    transition: background 0.2s, color 0.2s;
  }
  .faq__item[open] .faq__toggle { background: var(--color-brand-500); color: #fff; }
  .faq__minus { display: none; }
  .faq__item[open] .faq__plus { display: none; }
  .faq__item[open] .faq__minus { display: block; }

  .faq__a {
    overflow: hidden;
    color: var(--color-ink-soft);
    line-height: 1.7;
    font-size: 0.96rem;
    padding-bottom: 1.1rem;
    padding-right: 2.5rem;
  }
  .faq__item[open] .faq__a { animation: faqIn 0.3s ease; }
  @keyframes faqIn {
    from { opacity: 0; transform: translateY(-6px); }
    to { opacity: 1; transform: none; }
  }

  @media (min-width: 1024px) {
    .faq__inner { grid-template-columns: 0.8fr 1.2fr; gap: 4rem; }
    .faq__intro { position: sticky; top: 130px; }
  }
</style>
