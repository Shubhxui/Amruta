---
import { site } from "../data/site";
import Icon from "./Icon.astro";

const waNumber = site.contact.whatsapp.replace(/[^0-9]/g, "");
const addr = site.contact.address;
const mapEmbed = `https://www.google.com/maps?q=${encodeURIComponent(site.contact.mapQuery)}&output=embed`;
---

<section id="contact" class="contact">
  <div class="container-page">
    <div class="contact__head reveal">
      <span class="eyebrow eyebrow--light">Book an appointment</span>
      <h2 class="contact__title h-section">Let's plan the gentle care you deserve</h2>
      <p class="contact__sub">
        Share a few details and our team will call you back to confirm your visit.
        For anything urgent, please call us directly — we're here 24×7.
      </p>
    </div>

    <div class="contact__grid">
      <form id="apptForm" class="contact__form reveal" data-wa={waNumber}>
        <div class="field">
          <label for="f-name">Full name</label>
          <input id="f-name" name="name" type="text" required placeholder="Your name" />
        </div>
        <div class="field-row">
          <div class="field">
            <label for="f-phone">Phone number</label>
            <input id="f-phone" name="phone" type="tel" required placeholder="+91 ..." />
          </div>
          <div class="field">
            <label for="f-service">Service</label>
            <select id="f-service" name="service">
              {site.services.map((s) => <option value={s.title}>{s.title}</option>)}
              <option value="General enquiry">General enquiry</option>
            </select>
          </div>
        </div>
        <div class="field">
          <label for="f-date">Preferred date</label>
          <input id="f-date" name="date" type="date" />
        </div>
        <div class="field">
          <label for="f-msg">Message (optional)</label>
          <textarea id="f-msg" name="message" rows="3" placeholder="Tell us briefly how we can help"></textarea>
        </div>
        <button type="submit" class="btn btn-primary contact__submit">
          <Icon name="chat" class="w-[18px] h-[18px]" /> Request appointment
        </button>
        <p class="contact__formnote" id="apptNote">You'll be taken to WhatsApp to send your request to our care team.</p>
      </form>

      <div class="contact__info reveal" data-delay="120">
        <ul class="contact__details">
          <li>
            <span class="contact__icon"><Icon name="location" class="w-5 h-5" /></span>
            <div><strong>Visit us</strong><p>{addr.line1}, {addr.line2}, {addr.city}, {addr.state} {addr.pin}</p></div>
          </li>
          <li>
            <a href={site.contact.phoneHref}>
              <span class="contact__icon"><Icon name="phone" class="w-5 h-5" /></span>
              <div><strong>Call / WhatsApp</strong><p>{site.contact.phone}</p></div>
            </a>
          </li>
          <li>
            <a href={`mailto:${site.contact.email}`}>
              <span class="contact__icon"><Icon name="mail" class="w-5 h-5" /></span>
              <div><strong>Email us</strong><p>{site.contact.email}</p></div>
            </a>
          </li>
          <li>
            <span class="contact__icon"><Icon name="clock" class="w-5 h-5" /></span>
            <div><strong>Timings</strong>{site.contact.hours.map((h) => <p>{h.day} · {h.time}</p>)}</div>
          </li>
        </ul>
        <div class="contact__map">
          <iframe title="Map to Amruta Maternity Hospital" src={mapEmbed} loading="lazy" referrerpolicy="no-referrer-when-downgrade" allowfullscreen></iframe>
        </div>
      </div>
    </div>
  </div>
</section>

<style>
  .contact { padding-block: clamp(4rem, 8vw, 6.5rem); background: var(--color-dark); color: #fff; }
  .contact__head { max-width: 42rem; margin: 0 auto clamp(2.5rem, 5vw, 3.5rem); text-align: center; }
  .contact__head .eyebrow { justify-content: center; }
  .contact__title { color: #fff; margin-top: 1rem; }
  .contact__sub { margin-top: 1rem; color: rgba(255,255,255,0.64); line-height: 1.65; }

  .contact__grid { display: grid; grid-template-columns: 1fr; gap: 1.5rem; align-items: start; }

  .contact__form {
    background: #fff; color: var(--color-ink);
    border-radius: var(--radius-xl); padding: 1.9rem;
    display: flex; flex-direction: column; gap: 1.05rem;
  }
  .field { display: flex; flex-direction: column; gap: 0.4rem; }
  .field-row { display: grid; grid-template-columns: 1fr; gap: 1.05rem; }
  .field label { font-size: 0.82rem; font-weight: 500; }
  .field input, .field select, .field textarea {
    width: 100%; font: inherit; font-size: 0.95rem; color: var(--color-ink);
    background: var(--color-cream-soft); border: 1.5px solid var(--color-line);
    border-radius: var(--radius-md); padding: 0.8rem 0.95rem;
    transition: border-color 0.2s, box-shadow 0.2s;
  }
  .field textarea { resize: vertical; }
  .field input:focus, .field select:focus, .field textarea:focus {
    outline: none; border-color: var(--color-ink);
    box-shadow: 0 0 0 3px color-mix(in srgb, var(--color-accent) 60%, transparent);
  }
  .contact__submit { width: 100%; margin-top: 0.3rem; }
  .contact__formnote { font-size: 0.78rem; color: var(--color-ink-soft); text-align: center; }

  .contact__details { display: grid; gap: 0.5rem; }
  .contact__details li, .contact__details li > * { display: flex; align-items: flex-start; gap: 0.9rem; }
  .contact__details a { color: inherit; text-decoration: none; }
  .contact__details li {
    padding: 1rem 1.1rem; background: rgba(255,255,255,0.05);
    border: 1px solid rgba(255,255,255,0.1); border-radius: var(--radius-lg);
    transition: background 0.2s;
  }
  .contact__details li:hover { background: rgba(255,255,255,0.09); }
  .contact__icon {
    flex: none; display: inline-flex; align-items: center; justify-content: center;
    width: 44px; height: 44px; border-radius: 999px;
    background: var(--color-accent); color: var(--color-ink);
  }
  .contact__details strong { display: block; font-size: 0.95rem; font-weight: 600; }
  .contact__details p { color: rgba(255,255,255,0.62); font-size: 0.88rem; line-height: 1.45; }

  .contact__map {
    margin-top: 1.25rem; border-radius: var(--radius-lg); overflow: hidden;
    border: 1px solid rgba(255,255,255,0.14); height: 240px;
  }
  .contact__map iframe { width: 100%; height: 100%; border: 0; display: block; }

  @media (min-width: 560px) { .field-row { grid-template-columns: 1fr 1fr; } }
  @media (min-width: 1000px) { .contact__grid { grid-template-columns: 1fr 1fr; gap: 2.5rem; } }
</style>

<script>
  const form = document.getElementById("apptForm") as HTMLFormElement | null;
  form?.addEventListener("submit", (e) => {
    e.preventDefault();
    const data = new FormData(form);
    const wa = form.dataset.wa || "";
    const lines = [
      "Hello Amruta Maternity Hospital, I'd like to book an appointment.",
      "",
      `Name: ${data.get("name") || "-"}`,
      `Phone: ${data.get("phone") || "-"}`,
      `Service: ${data.get("service") || "-"}`,
      `Preferred date: ${data.get("date") || "-"}`,
    ];
    const msg = (data.get("message") || "").toString().trim();
    if (msg) lines.push(`Message: ${msg}`);
    const url = `https://wa.me/${wa}?text=${encodeURIComponent(lines.join("\n"))}`;
    window.open(url, "_blank", "noopener");
    const note = document.getElementById("apptNote");
    if (note) { note.textContent = "Thank you! Opening WhatsApp so you can send your request…"; }
  });
</script>
