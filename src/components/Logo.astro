---
/**
 * Amruta Maternity Hospital — logo lockup.
 * Minimal: a small lotus mark (ink + one lime petal) + bold wordmark.
 * variant="light" is for dark backgrounds.
 */
interface Props {
  variant?: "default" | "light";
  href?: string | null;
  class?: string;
}
const { variant = "default", href = import.meta.env.BASE_URL, class: className = "" } = Astro.props;

const isLight = variant === "light";
const ink = isLight ? "#ffffff" : "#0e0e0e";
const sub = isLight ? "rgba(255,255,255,0.6)" : "#6e6e6e";
const Tag = href ? "a" : "div";
---

<Tag
  {...href ? { href } : {}}
  class={`logo ${className}`}
  aria-label="Amruta Maternity Hospital — home"
>
  <svg class="logo__mark" width="34" height="34" viewBox="0 0 48 48" fill="none" aria-hidden="true" xmlns="http://www.w3.org/2000/svg">
    <path d="M24 11 C29.5 19, 29.5 27, 24 33 C18.5 27, 18.5 19, 24 11 Z" fill={ink} opacity="0.55" transform="rotate(64 24 33)" />
    <path d="M24 11 C29.5 19, 29.5 27, 24 33 C18.5 27, 18.5 19, 24 11 Z" fill={ink} opacity="0.55" transform="rotate(-64 24 33)" />
    <path d="M24 10 C29.5 18, 29.5 26, 24 33 C18.5 26, 18.5 18, 24 10 Z" fill={ink} opacity="0.82" transform="rotate(33 24 33)" />
    <path d="M24 10 C29.5 18, 29.5 26, 24 33 C18.5 26, 18.5 18, 24 10 Z" fill={ink} opacity="0.82" transform="rotate(-33 24 33)" />
    <path d="M24 8 C30 17, 30 25, 24 33 C18 25, 18 17, 24 8 Z" fill="#d9b1a3" stroke={ink} stroke-width="1" />
  </svg>

  <span class="logo__text">
    <span class="logo__word" style={`color:${ink}`}>Amruta</span>
    <span class="logo__sub" style={`color:${sub}`}>Maternity&nbsp;Hospital</span>
  </span>
</Tag>

<style>
  .logo { display: inline-flex; align-items: center; gap: 0.55rem; text-decoration: none; }
  .logo__mark { flex: none; }
  .logo__text { display: flex; flex-direction: column; line-height: 1; }
  .logo__word {
    font-weight: 700;
    font-size: 1.45rem;
    letter-spacing: -0.035em;
  }
  .logo__sub {
    font-weight: 500;
    font-size: 0.58rem;
    letter-spacing: 0.22em;
    text-transform: uppercase;
    margin-top: 0.3rem;
  }
</style>
