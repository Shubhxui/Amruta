---
import { site } from "../data/site";
import Icon from "./Icon.astro";
---

<section id="services" class="services">
  <div class="container-page">
    <div class="section-head reveal">
      <span class="eyebrow">What we offer</span>
      <h2 class="section-title h-section">Complete care for mother &amp; baby</h2>
      <p class="section-sub lead">
        From planning a pregnancy to your newborn's first check-up, every service
        is delivered with expertise and a gentle, personal touch.
      </p>
    </div>

    <div class="services__grid">
      {site.services.map((service, i) => (
        <article class="card card-hover services__card reveal" data-delay={i * 60}>
          <span class="services__icon"><Icon name={service.icon} class="w-6 h-6" /></span>
          <h3 class="services__card-title">{service.title}</h3>
          <p class="services__card-text">{service.text}</p>
          <a href="#contact" class="services__link" aria-label={`Enquire about ${service.title}`}>
            Enquire <Icon name="arrowUpRight" class="w-4 h-4" />
          </a>
        </article>
      ))}
    </div>
  </div>
</section>

<style>
  .services { padding-block: clamp(4rem, 8vw, 6.5rem); background: var(--color-paper); }

  .section-head { max-width: 42rem; margin: 0 auto clamp(2.5rem, 5vw, 3.5rem); text-align: center; }
  .section-head .eyebrow { justify-content: center; }
  .section-title { margin-top: 1rem; }
  .section-sub { margin-top: 1rem; }

  .services__grid {
    display: grid;
    grid-template-columns: 1fr;
    gap: 1.1rem;
  }
  .services__card { padding: 1.9rem; display: flex; flex-direction: column; }
  .services__icon {
    display: inline-flex; align-items: center; justify-content: center;
    width: 54px; height: 54px; border-radius: 999px;
    background: var(--color-cream); color: var(--color-ink);
    margin-bottom: 1.3rem;
    transition: background 0.25s, color 0.25s;
  }
  .services__card:hover .services__icon { background: var(--color-accent); }
  .services__card-title { font-size: 1.25rem; font-weight: 600; }
  .services__card-text { margin-top: 0.6rem; color: var(--color-ink-soft); line-height: 1.6; font-size: 0.95rem; flex: 1; }
  .services__link {
    margin-top: 1.4rem;
    display: inline-flex; align-items: center; gap: 0.35rem;
    font-weight: 500; font-size: 0.9rem; color: var(--color-ink);
    text-decoration: none;
  }
  .services__link svg { transition: transform 0.2s; }
  .services__card:hover .services__link svg { transform: translate(3px, -3px); }

  @media (min-width: 640px) { .services__grid { grid-template-columns: 1fr 1fr; } }
  @media (min-width: 1000px) { .services__grid { grid-template-columns: repeat(3, 1fr); gap: 1.25rem; } }
</style>
