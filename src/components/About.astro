---
import { site } from "../data/site";
import Icon from "./Icon.astro";
import { asset } from "../lib/asset";

const points = [
  "Senior obstetricians & gynaecologists",
  "Normal & painless delivery options",
  "Level-II NICU for newborn care",
  "Warm, private & hygienic rooms",
];
const years = new Date().getFullYear() - site.established;
---

<section id="about" class="about">
  <div class="container-page about__inner">
    <div class="about__media reveal">
      <div class="about__frame">
        <img
          src={asset("images/about.jpg")}
          alt="A caring doctor consulting with an expecting mother at Amruta Maternity Hospital"
          width="900"
          height="1000"
          loading="lazy"
          decoding="async"
        />
      </div>
      <div class="about__badge">
        <span class="about__badge-num">{years}+</span>
        <span class="about__badge-text">years of trusted<br />maternity care</span>
      </div>
    </div>

    <div class="about__copy">
      <span class="eyebrow reveal">About Amruta</span>
      <h2 class="about__title h-section reveal" data-delay="60">
        A gentle, modern home for women's &amp; newborn health
      </h2>
      <p class="about__text lead reveal" data-delay="120">
        Since {site.established}, {site.name} has been a trusted name in Tathawade
        for safe deliveries and complete women's healthcare — blending experienced
        specialists, modern facilities and genuinely warm care.
      </p>

      <ul class="about__list reveal" data-delay="180">
        {points.map((p) => (
          <li class="about__list-item">
            <span class="about__check"><Icon name="check" class="w-4 h-4" strokeWidth={2.4} /></span>
            {p}
          </li>
        ))}
      </ul>

      <div class="about__cta reveal" data-delay="220">
        <a href="#doctors" class="btn btn-dark">Meet our team</a>
        <a href={site.contact.phoneHref} class="about__call">
          <span class="about__call-icon"><Icon name="phone" class="w-5 h-5" /></span>
          <span><small>Talk to us today</small><strong>{site.contact.phone}</strong></span>
        </a>
      </div>
    </div>
  </div>
</section>

<style>
  .about { padding-block: clamp(4rem, 8vw, 6.5rem); background: var(--color-paper); }
  .about__inner { display: grid; gap: clamp(2.5rem, 5vw, 4rem); align-items: center; }

  .about__media { position: relative; }
  .about__frame {
    border-radius: var(--radius-2xl);
    overflow: hidden;
    aspect-ratio: 5 / 5.4;
    background: var(--color-cream);
  }
  .about__frame img { width: 100%; height: 100%; object-fit: cover; }
  .about__badge {
    position: absolute;
    left: 1.25rem; bottom: 1.25rem;
    background: var(--color-accent);
    color: var(--color-ink);
    padding: 1rem 1.3rem;
    border-radius: var(--radius-lg);
    display: flex; align-items: center; gap: 0.75rem;
    box-shadow: 0 18px 40px -18px rgba(14,14,14,0.45);
  }
  .about__badge-num { font-size: 2.1rem; font-weight: 600; letter-spacing: -0.03em; line-height: 1; }
  .about__badge-text { font-size: 0.78rem; line-height: 1.3; font-weight: 500; }

  .about__title { margin-top: 1rem; }
  .about__text { margin-top: 1.1rem; max-width: 34rem; }
  .about__list { margin-top: 1.6rem; display: grid; grid-template-columns: 1fr; gap: 0.8rem; }
  .about__list-item { display: flex; align-items: center; gap: 0.7rem; font-weight: 500; color: var(--color-ink); }
  .about__check {
    flex: none; display: inline-flex; align-items: center; justify-content: center;
    width: 26px; height: 26px; border-radius: 999px;
    background: var(--color-accent); color: var(--color-ink);
  }

  .about__cta { margin-top: 2rem; display: flex; align-items: center; gap: 1.5rem; flex-wrap: wrap; }
  .about__call { display: inline-flex; align-items: center; gap: 0.7rem; text-decoration: none; color: inherit; }
  .about__call-icon {
    display: inline-flex; align-items: center; justify-content: center;
    width: 46px; height: 46px; border-radius: 999px;
    background: var(--color-cream); color: var(--color-ink);
  }
  .about__call small { display: block; font-size: 0.78rem; color: var(--color-ink-soft); }
  .about__call strong { font-size: 1.02rem; font-weight: 600; }

  @media (min-width: 640px) { .about__list { grid-template-columns: 1fr 1fr; } }
  @media (min-width: 960px) { .about__inner { grid-template-columns: 0.95fr 1.05fr; gap: 4.5rem; } }
</style>
