---
import { site } from "../data/site";
import Icon from "./Icon.astro";
---

<section id="testimonials" class="tms">
  <div class="container-page">
    <div class="section-head reveal">
      <span class="eyebrow is-centered"><Icon name="heart" class="w-4 h-4" /> Happy parents</span>
      <h2 class="section-title">Stories from families we've cared for</h2>
      <p class="section-sub">
        Nothing means more to us than the trust of the mothers and families who
        chose Amruta for their most precious moments.
      </p>
    </div>

    <div class="tms__grid">
      {site.testimonials.map((t, i) => (
        <figure class="tms__card reveal" data-delay={i * 80}>
          <span class="tms__quote"><Icon name="quote" class="w-8 h-8" /></span>
          <div class="tms__stars" aria-label="5 out of 5 stars">
            <Icon name="star" class="w-4 h-4" /><Icon name="star" class="w-4 h-4" />
            <Icon name="star" class="w-4 h-4" /><Icon name="star" class="w-4 h-4" />
            <Icon name="star" class="w-4 h-4" />
          </div>
          <blockquote class="tms__text">{t.quote}</blockquote>
          <figcaption class="tms__author">
            <span class="tms__avatar" aria-hidden="true">{t.name.charAt(0)}</span>
            <span>
              <strong>{t.name}</strong>
              <small>{t.detail}</small>
            </span>
          </figcaption>
        </figure>
      ))}
    </div>
  </div>
</section>

<style>
  .tms {
    padding-block: 5rem;
    background:
      radial-gradient(70% 60% at 50% 0%, var(--color-brand-50), transparent 70%),
      var(--color-cream-100);
  }
  .tms__grid {
    display: grid;
    grid-template-columns: 1fr;
    gap: 1.5rem;
  }
  .tms__card {
    position: relative;
    background: #fff;
    border: 1px solid var(--color-cream-300);
    border-radius: var(--radius-2xl);
    padding: 2.5rem 1.85rem 1.85rem;
    box-shadow: 0 1px 2px rgba(44, 36, 38, 0.04);
  }
  .tms__quote {
    position: absolute;
    top: 1.4rem;
    right: 1.6rem;
    color: var(--color-brand-100);
  }
  .tms__stars { display: flex; gap: 2px; color: var(--color-peach-500); }
  .tms__text {
    margin-top: 1rem;
    color: var(--color-ink);
    line-height: 1.7;
    font-size: 1.02rem;
  }
  .tms__author {
    margin-top: 1.6rem;
    padding-top: 1.4rem;
    border-top: 1px solid var(--color-cream-200);
    display: flex;
    align-items: center;
    gap: 0.85rem;
  }
  .tms__avatar {
    flex: none;
    display: inline-flex; align-items: center; justify-content: center;
    width: 46px; height: 46px; border-radius: 50%;
    background: linear-gradient(140deg, var(--color-brand-300), var(--color-brand-600));
    color: #fff;
    font-family: var(--font-display);
    font-weight: 600;
    font-size: 1.2rem;
  }
  .tms__author strong { display: block; }
  .tms__author small { color: var(--color-ink-soft); font-size: 0.82rem; }

  @media (min-width: 768px) {
    .tms__grid { grid-template-columns: repeat(3, 1fr); }
  }
</style>
