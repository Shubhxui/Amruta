---
import { site } from "../data/site";
import Logo from "./Logo.astro";
import Icon from "./Icon.astro";
---

<header id="siteHeader" class="site-header">
  <!-- Utility bar -->
  <div class="util-bar">
    <div class="container-page util-bar__inner">
      <div class="util-bar__left">
        <span class="util-item">
          <Icon name="location" class="w-4 h-4" />
          {site.contact.address.line1}, {site.contact.address.city}
        </span>
        <span class="util-item util-hide-sm">
          <Icon name="clock" class="w-4 h-4" />
          Open 24×7 for Emergencies
        </span>
      </div>
      <div class="util-bar__right">
        <a href={site.contact.phoneHref} class="util-item util-strong">
          <Icon name="phone" class="w-4 h-4" />
          {site.contact.phone}
        </a>
        <span class="util-divider util-hide-sm"></span>
        <div class="util-social util-hide-sm">
          <a href={site.social.facebook} aria-label="Facebook"><Icon name="facebook" class="w-4 h-4" /></a>
          <a href={site.social.instagram} aria-label="Instagram"><Icon name="instagram" class="w-4 h-4" /></a>
          <a href={site.social.youtube} aria-label="YouTube"><Icon name="youtube" class="w-4 h-4" /></a>
        </div>
      </div>
    </div>
  </div>

  <!-- Main nav -->
  <div class="nav-bar">
    <div class="container-page nav-bar__inner">
      <Logo />

      <nav class="nav-links" aria-label="Primary">
        {site.nav.map((item) => (
          <a href={item.href} class="nav-link">{item.label}</a>
        ))}
      </nav>

      <div class="nav-actions">
        <a href="#contact" class="btn btn-primary nav-cta">
          <Icon name="calendar" class="w-[18px] h-[18px]" />
          Book Appointment
        </a>
        <button id="navToggle" class="nav-toggle" aria-label="Open menu" aria-expanded="false" aria-controls="mobileMenu">
          <Icon name="menu" class="w-6 h-6" />
        </button>
      </div>
    </div>
  </div>

  <!-- Mobile menu -->
  <div id="mobileMenu" class="mobile-menu" hidden>
    <nav class="mobile-menu__nav" aria-label="Mobile">
      {site.nav.map((item) => (
        <a href={item.href} class="mobile-link" data-close>{item.label}</a>
      ))}
    </nav>
    <a href={site.contact.phoneHref} class="btn btn-outline w-full mobile-call" data-close>
      <Icon name="phone" class="w-[18px] h-[18px]" /> Call {site.contact.phone}
    </a>
    <a href="#contact" class="btn btn-primary w-full" data-close>
      <Icon name="calendar" class="w-[18px] h-[18px]" /> Book Appointment
    </a>
  </div>
</header>

<style>
  .site-header {
    position: sticky;
    top: 0;
    z-index: 50;
  }

  /* Utility bar */
  .util-bar {
    background: var(--color-sage-700);
    color: rgba(255, 255, 255, 0.85);
    font-size: 0.8rem;
  }
  .util-bar__inner {
    display: flex;
    align-items: center;
    justify-content: space-between;
    height: 42px;
  }
  .util-bar__left,
  .util-bar__right {
    display: flex;
    align-items: center;
    gap: 1.25rem;
  }
  .util-item {
    display: inline-flex;
    align-items: center;
    gap: 0.4rem;
    color: inherit;
    text-decoration: none;
  }
  .util-strong { font-weight: 600; color: #fff; }
  .util-strong:hover { color: var(--color-peach-300); }
  .util-divider {
    width: 1px;
    height: 18px;
    background: rgba(255, 255, 255, 0.25);
  }
  .util-social { display: flex; gap: 0.75rem; }
  .util-social a { color: rgba(255, 255, 255, 0.8); transition: color 0.2s; }
  .util-social a:hover { color: #fff; }

  /* Nav bar */
  .nav-bar {
    background: color-mix(in srgb, var(--color-cream-100) 88%, transparent);
    backdrop-filter: blur(10px);
    border-bottom: 1px solid transparent;
    transition: background 0.3s ease, box-shadow 0.3s ease, border-color 0.3s ease;
  }
  .site-header.is-scrolled .nav-bar {
    background: color-mix(in srgb, #ffffff 92%, transparent);
    box-shadow: 0 10px 30px -18px rgba(44, 36, 38, 0.4);
    border-color: var(--color-cream-300);
  }
  .nav-bar__inner {
    display: flex;
    align-items: center;
    justify-content: space-between;
    height: 78px;
  }

  .nav-links {
    display: none;
    align-items: center;
    gap: 0.35rem;
  }
  .nav-link {
    position: relative;
    padding: 0.5rem 0.85rem;
    font-size: 0.92rem;
    font-weight: 500;
    color: var(--color-ink);
    text-decoration: none;
    border-radius: 999px;
    transition: color 0.2s, background 0.2s;
  }
  .nav-link::after {
    content: "";
    position: absolute;
    left: 0.85rem;
    right: 0.85rem;
    bottom: 0.28rem;
    height: 2px;
    background: var(--color-brand-500);
    border-radius: 2px;
    transform: scaleX(0);
    transform-origin: left;
    transition: transform 0.25s ease;
  }
  .nav-link:hover { color: var(--color-brand-600); }
  .nav-link:hover::after { transform: scaleX(1); }

  .nav-actions { display: flex; align-items: center; gap: 0.75rem; }
  .nav-cta { display: none; }

  .nav-toggle {
    display: inline-flex;
    align-items: center;
    justify-content: center;
    width: 46px;
    height: 46px;
    border-radius: 14px;
    background: #fff;
    color: var(--color-ink);
    border: 1px solid var(--color-cream-300);
  }

  /* Mobile menu */
  .mobile-menu {
    background: #fff;
    border-bottom: 1px solid var(--color-cream-300);
    box-shadow: 0 20px 40px -20px rgba(44, 36, 38, 0.3);
    padding: 1rem 1.5rem 1.5rem;
    display: flex;
    flex-direction: column;
    gap: 0.6rem;
  }
  .mobile-menu[hidden] { display: none; }
  .mobile-menu__nav { display: flex; flex-direction: column; }
  .mobile-link {
    padding: 0.85rem 0.5rem;
    font-weight: 500;
    color: var(--color-ink);
    text-decoration: none;
    border-bottom: 1px solid var(--color-cream-200);
  }
  .mobile-link:hover { color: var(--color-brand-600); }
  .mobile-call { margin-top: 0.5rem; }
  .w-full { width: 100%; }

  @media (min-width: 1024px) {
    .nav-links { display: flex; }
    .nav-cta { display: inline-flex; }
    .nav-toggle { display: none; }
  }
  @media (max-width: 1023px) {
    .mobile-menu { display: flex; }
  }
</style>

<script>
  // Header scroll state
  const header = document.getElementById("siteHeader");
  const onScroll = () => {
    if (!header) return;
    header.classList.toggle("is-scrolled", window.scrollY > 12);
  };
  onScroll();
  window.addEventListener("scroll", onScroll, { passive: true });

  // Mobile menu toggle
  const toggle = document.getElementById("navToggle");
  const menu = document.getElementById("mobileMenu");
  const setMenu = (open: boolean) => {
    if (!menu || !toggle) return;
    menu.hidden = !open;
    toggle.setAttribute("aria-expanded", String(open));
    toggle.setAttribute("aria-label", open ? "Close menu" : "Open menu");
  };
  toggle?.addEventListener("click", () => setMenu(menu?.hidden ?? true));
  menu?.querySelectorAll("[data-close]").forEach((el) =>
    el.addEventListener("click", () => setMenu(false))
  );
  // Close mobile menu when resizing up to desktop
  window.matchMedia("(min-width: 1024px)").addEventListener("change", (e) => {
    if (e.matches) setMenu(false);
  });
</script>
