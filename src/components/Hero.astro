---
import { site } from "../data/site";
import Icon from "./Icon.astro";
import { asset } from "../lib/asset";

const heroStats = [
  { value: "15+", label: "Years of care" },
  { value: "12K+", label: "Safe deliveries" },
  { value: "98%", label: "Would recommend" },
];
const avatars = ["images/testimonial-1.jpg", "images/testimonial-2.jpg", "images/testimonial-3.jpg"];
---

<section id="home" class="hero">
  <div class="hero__grid">
    <div class="hero__left">
      <div class="hero__content">
        <span class="eyebrow reveal">Maternity · Gynaecology · Newborn care</span>

        <h1 class="hero__title h-display reveal" data-delay="60">
          Caring hands for every new beginning
        </h1>

        <p class="hero__lead lead reveal" data-delay="120">
          At {site.name}, Tathawade, our specialists give you calm, compassionate
          care through pregnancy, childbirth and beyond — so you can focus on the
          joy of welcoming your little one.
        </p>

        <div class="hero__actions reveal" data-delay="180">
          <a href="#contact" class="btn btn-primary">
            <Icon name="calendar" class="w-[18px] h-[18px]" /> Book an Appointment
          </a>
          <a href="#services" class="btn btn-white">
            Our Services <Icon name="arrowRight" class="w-[18px] h-[18px]" />
          </a>
        </div>

        <div class="hero__trust reveal" data-delay="240">
          <div class="hero__avatars" aria-hidden="true">
            {avatars.map((a) => (
              <img src={asset(a)} alt="" width="40" height="40" loading="eager" />
            ))}
            <span class="hero__avatars-more">30K+</span>
          </div>
          <p class="hero__trust-text">
            Trusted by <strong>30,000+ families</strong> across Pune for safe,
            gentle maternity care.
          </p>
        </div>

        <dl class="hero__stats reveal" data-delay="300">
          {heroStats.map((s) => (
            <div class="hero__stat">
              <dt>{s.value}</dt>
              <dd>{s.label}</dd>
            </div>
          ))}
        </dl>
      </div>
    </div>

    <div class="hero__right reveal">
      <img
        src={asset("images/hero.jpg")}
        alt="A mother gently holding her newborn baby at Amruta Maternity Hospital"
        width="900"
        height="1120"
        loading="eager"
        decoding="async"
        fetchpriority="high"
      />
    </div>
  </div>
</section>

<style>
  .hero { background: var(--color-cream); overflow: hidden; }
  .hero__grid {
    display: grid;
    grid-template-columns: 1fr;
  }

  .hero__left {
    display: flex;
    align-items: center;
    padding: clamp(2.5rem, 7vw, 3.5rem) 1.25rem clamp(2.5rem, 7vw, 3.5rem);
  }
  .hero__content {
    width: 100%;
    max-width: 36rem;
    margin-inline: auto;
    text-align: center;
  }

  .hero__title { margin-top: 1.3rem; }
  .hero__lead { margin-top: 1.3rem; margin-inline: auto; max-width: 34rem; }

  .hero__actions {
    margin-top: 2rem;
    display: flex;
    flex-wrap: wrap;
    gap: 0.8rem;
    justify-content: center;
  }

  .hero__trust {
    margin-top: 2.2rem;
    display: flex;
    align-items: center;
    gap: 0.9rem;
    justify-content: center;
    flex-wrap: wrap;
  }
  .hero__avatars { display: flex; align-items: center; }
  .hero__avatars img {
    width: 40px; height: 40px;
    border-radius: 999px;
    object-fit: cover;
    border: 2.5px solid var(--color-cream);
    margin-left: -10px;
  }
  .hero__avatars img:first-child { margin-left: 0; }
  .hero__avatars-more {
    margin-left: -10px;
    display: inline-flex; align-items: center; justify-content: center;
    width: 40px; height: 40px; border-radius: 999px;
    background: var(--color-ink); color: #fff;
    font-size: 0.72rem; font-weight: 600;
    border: 2.5px solid var(--color-cream);
  }
  .hero__trust-text { font-size: 0.92rem; color: var(--color-ink-soft); line-height: 1.45; max-width: 16rem; text-align: left; }
  .hero__trust-text strong { color: var(--color-ink); font-weight: 600; }

  .hero__stats {
    margin-top: 2.4rem;
    display: grid;
    grid-template-columns: repeat(3, 1fr);
    gap: 0.5rem;
    padding-top: 1.8rem;
    border-top: 1px solid var(--color-line);
  }
  .hero__stat dt {
    font-size: clamp(1.6rem, 5vw, 2.3rem);
    font-weight: 600;
    letter-spacing: -0.03em;
    color: var(--color-ink);
    line-height: 1;
  }
  .hero__stat dd { margin-top: 0.45rem; font-size: 0.8rem; color: var(--color-ink-soft); }

  .hero__right { position: relative; min-height: 56vw; max-height: 460px; }
  .hero__right img { position: absolute; inset: 0; width: 100%; height: 100%; object-fit: cover; object-position: center 30%; }

  /* Desktop: split, content aligned to container, image full-bleed right */
  @media (min-width: 992px) {
    .hero__grid { grid-template-columns: 1.02fr 0.98fr; min-height: min(86vh, 820px); }
    .hero__left {
      justify-content: flex-end;
      padding: 4rem clamp(2.5rem, 4vw, 4rem) 4rem max(2.5rem, calc((100vw - 78rem) / 2 + 2.5rem));
    }
    .hero__content { margin-inline: 0; text-align: left; max-width: 34rem; }
    .hero__title, .hero__lead { margin-inline: 0; }
    .hero__actions, .hero__trust { justify-content: flex-start; }
    .hero__right { min-height: 100%; max-height: none; }
  }
  @media (min-width: 1280px) {
    .hero__left { padding-block: 5rem; }
  }
</style>
