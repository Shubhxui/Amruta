---
import { site } from "../data/site";
import Icon from "./Icon.astro";
const waNumber = site.contact.whatsapp.replace(/[^0-9]/g, "");
---

<div class="fab">
  <a
    class="fab__btn fab__btn--wa"
    href={`https://wa.me/${waNumber}`}
    target="_blank"
    rel="noopener"
    aria-label="Chat with us on WhatsApp"
  >
    <Icon name="chat" class="w-6 h-6" />
    <span class="fab__pulse"></span>
  </a>
  <a class="fab__btn fab__btn--call" href={site.contact.phoneHref} aria-label="Call us">
    <Icon name="phone" class="w-6 h-6" />
  </a>
</div>

<style>
  .fab {
    position: fixed;
    right: 1.1rem;
    bottom: 1.1rem;
    z-index: 40;
    display: flex;
    flex-direction: column;
    gap: 0.7rem;
  }
  .fab__btn {
    position: relative;
    display: inline-flex;
    align-items: center;
    justify-content: center;
    width: 54px; height: 54px;
    border-radius: 50%;
    color: #fff;
    box-shadow: 0 14px 30px -10px rgba(44, 36, 38, 0.6);
    transition: transform 0.2s;
  }
  .fab__btn:hover { transform: scale(1.06); }
  .fab__btn--wa { background: #25d366; }
  .fab__btn--call { background: var(--color-brand-500); }
  .fab__pulse {
    position: absolute;
    inset: 0;
    border-radius: 50%;
    border: 2px solid #25d366;
    animation: fabPulse 2.2s ease-out infinite;
  }
  @keyframes fabPulse {
    0% { transform: scale(1); opacity: 0.8; }
    100% { transform: scale(1.7); opacity: 0; }
  }
  @media (prefers-reduced-motion: reduce) {
    .fab__pulse { display: none; }
  }
  @media (min-width: 1024px) {
    .fab { right: 1.6rem; bottom: 1.6rem; }
    .fab__btn { width: 58px; height: 58px; }
  }
</style>
