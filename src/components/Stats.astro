---
import { site } from "../data/site";
---

<section class="stats" aria-label="Hospital at a glance">
  <div class="container-page">
    <div class="stats__grid">
      {site.stats.map((stat) => (
        <div class="stats__item reveal">
          <div class="stats__value">
            <span class="counter" data-target={stat.value}>0</span>{stat.suffix}
          </div>
          <p class="stats__label">{stat.label}</p>
        </div>
      ))}
    </div>
  </div>
</section>

<style>
  .stats {
    position: relative;
    margin-top: -1.5rem;
    z-index: 2;
  }
  .stats__grid {
    background: var(--color-sage-700);
    color: #fff;
    border-radius: var(--radius-2xl);
    padding: 2.25rem 1.5rem;
    display: grid;
    grid-template-columns: repeat(2, 1fr);
    gap: 1.75rem 1rem;
    box-shadow: 0 30px 60px -34px rgba(36, 53, 48, 0.7);
    background-image:
      radial-gradient(80% 120% at 100% 0%, rgba(224, 163, 106, 0.18), transparent 60%),
      radial-gradient(80% 120% at 0% 100%, rgba(191, 92, 102, 0.18), transparent 60%);
  }
  .stats__item {
    text-align: center;
    position: relative;
  }
  .stats__value {
    font-family: var(--font-display);
    font-size: clamp(2rem, 5vw, 2.9rem);
    font-weight: 600;
    color: #fff;
    line-height: 1;
  }
  .stats__label {
    margin-top: 0.5rem;
    font-size: 0.86rem;
    color: rgba(255, 255, 255, 0.78);
    letter-spacing: 0.02em;
  }

  @media (min-width: 768px) {
    .stats__grid {
      grid-template-columns: repeat(4, 1fr);
      padding: 2.5rem 2rem;
    }
    .stats__item:not(:last-child)::after {
      content: "";
      position: absolute;
      right: -0.5rem;
      top: 50%;
      transform: translateY(-50%);
      width: 1px;
      height: 56px;
      background: rgba(255, 255, 255, 0.16);
    }
  }
</style>

<script>
  const reduce = window.matchMedia("(prefers-reduced-motion: reduce)").matches;
  const fmt = (n: number) => {
    if (n >= 1000) return Math.round(n).toLocaleString("en-IN");
    return String(Math.round(n));
  };
  const animate = (el: HTMLElement) => {
    const target = Number(el.dataset.target || "0");
    if (reduce) { el.textContent = fmt(target); return; }
    const dur = 1600;
    let start = 0;
    const startTs = performance.now();
    const tick = (now: number) => {
      const p = Math.min((now - startTs) / dur, 1);
      const eased = 1 - Math.pow(1 - p, 3);
      el.textContent = fmt(target * eased);
      if (p < 1) requestAnimationFrame(tick);
      else el.textContent = fmt(target);
    };
    requestAnimationFrame(tick);
    void start;
  };
  const counters = document.querySelectorAll<HTMLElement>(".counter");
  if (!("IntersectionObserver" in window)) {
    counters.forEach(animate);
  } else {
    const io = new IntersectionObserver((entries) => {
      entries.forEach((e) => {
        if (e.isIntersecting) {
          animate(e.target as HTMLElement);
          io.unobserve(e.target);
        }
      });
    }, { threshold: 0.6 });
    counters.forEach((c) => io.observe(c));
  }
</script>
