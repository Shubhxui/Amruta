---
/**
 * Inline SVG icon set. Stroke icons inherit currentColor.
 * Usage: <Icon name="phone" class="w-5 h-5" />
 */
interface Props {
  name: string;
  class?: string;
  strokeWidth?: number;
}
const { name, class: className = "w-6 h-6", strokeWidth = 1.6 } = Astro.props;

const icons: Record<string, string> = {
  // ---- service icons ----
  pregnancy: `<path d="M19 14c1.49-1.46 3-3.21 3-5.5A5.5 5.5 0 0 0 16.5 3c-1.76 0-3 .5-4.5 2-1.5-1.5-2.74-2-4.5-2A5.5 5.5 0 0 0 2 8.5c0 2.29 1.51 4.04 3 5.5l7 7Z"/><path d="M3.5 12h3l1.4-2.6 2.2 5 1.6-3.2 1 1.3h4.3"/>`,
  delivery: `<path d="M20 6c-2 0-4.5-1.19-6.24-2.72a1.17 1.17 0 0 0-1.52 0C10.5 4.81 8 6 6 6a1 1 0 0 0-1 1v6c0 5 3.5 7.5 6.67 8.94.21.09.45.09.66 0C16.5 20.5 20 18 20 13V7a1 1 0 0 0-1-1Z"/><path d="M12 9c-.7-.8-2.1-.5-2.1.8 0 1.05 2.1 2.3 2.1 2.3s2.1-1.25 2.1-2.3c0-1.3-1.4-1.6-2.1-.8Z"/>`,
  newborn: `<circle cx="12" cy="12" r="9"/><path d="M9 11h.01M15 11h.01"/><path d="M9.2 15c.8.7 1.8 1.1 2.8 1.1s2-.4 2.8-1.1"/><path d="M12 3c1.4 0 1.4 1.8 0 1.8"/>`,
  gynaec: `<circle cx="12" cy="8" r="5"/><path d="M12 13v8M9 18h6"/>`,
  laparoscopy: `<rect x="2.5" y="5" width="19" height="12" rx="2"/><path d="M6 11h2.5l1.4-2.6 2.1 5 1.5-3 1 .6H18"/><path d="M9 21h6M12 17v4"/>`,
  fertility: `<circle cx="12" cy="12" r="2.4"/><circle cx="12" cy="5.6" r="2.4"/><circle cx="17.6" cy="9.2" r="2.4"/><circle cx="15.4" cy="16.4" r="2.4"/><circle cx="8.6" cy="16.4" r="2.4"/><circle cx="6.4" cy="9.2" r="2.4"/>`,

  // ---- why-us / feature icons ----
  shield: `<path d="M20 13c0 5-3.5 7.5-7.66 8.95a1 1 0 0 1-.67 0C7.5 20.5 4 18 4 13V6a1 1 0 0 1 1-1c2 0 4.5-1.19 6.24-2.72a1.17 1.17 0 0 1 1.52 0C14.5 3.81 17 5 19 5a1 1 0 0 1 1 1Z"/><path d="m9 12 2 2 4-4"/>`,
  clock: `<circle cx="12" cy="12" r="9"/><path d="M12 7v5l3.5 2"/>`,
  heart: `<path d="M19 14c1.49-1.46 3-3.21 3-5.5A5.5 5.5 0 0 0 16.5 3c-1.76 0-3 .5-4.5 2-1.5-1.5-2.74-2-4.5-2A5.5 5.5 0 0 0 2 8.5c0 2.29 1.51 4.04 3 5.5l7 7Z"/>`,
  equipment: `<path d="M4.8 3v6a4 4 0 0 0 8 0V3"/><path d="M4.8 3H7M10.6 3h2.2"/><path d="M8.8 13v3a4.2 4.2 0 0 0 8.4 0v-1"/><circle cx="17.2" cy="13" r="2.2"/>`,

  // ---- UI icons ----
  phone: `<path d="M22 16.92v3a2 2 0 0 1-2.18 2 19.79 19.79 0 0 1-8.63-3.07 19.5 19.5 0 0 1-6-6 19.79 19.79 0 0 1-3.07-8.67A2 2 0 0 1 4.11 2h3a2 2 0 0 1 2 1.72c.13.96.36 1.9.7 2.81a2 2 0 0 1-.45 2.11L8.09 9.91a16 16 0 0 0 6 6l1.27-1.27a2 2 0 0 1 2.11-.45c.91.34 1.85.57 2.81.7A2 2 0 0 1 22 16.92Z"/>`,
  mail: `<rect x="2" y="4" width="20" height="16" rx="2"/><path d="m22 7-8.97 5.7a1.94 1.94 0 0 1-2.06 0L2 7"/>`,
  location: `<path d="M20 10c0 6-8 12-8 12s-8-6-8-12a8 8 0 0 1 16 0Z"/><circle cx="12" cy="10" r="3"/>`,
  arrowRight: `<path d="M5 12h14M13 5l7 7-7 7"/>`,
  arrowUpRight: `<path d="M7 17 17 7M8 7h9v9"/>`,
  plus: `<path d="M12 5v14M5 12h14"/>`,
  minus: `<path d="M5 12h14"/>`,
  check: `<path d="M20 6 9 17l-5-5"/>`,
  calendar: `<rect x="3" y="4.5" width="18" height="17" rx="2"/><path d="M3 9.5h18M8 2.5v4M16 2.5v4"/>`,
  chat: `<path d="M21 11.5a8.38 8.38 0 0 1-.9 3.8 8.5 8.5 0 0 1-7.6 4.7 8.38 8.38 0 0 1-3.8-.9L3 21l1.9-5.7a8.38 8.38 0 0 1-.9-3.8 8.5 8.5 0 0 1 4.7-7.6 8.38 8.38 0 0 1 3.8-.9h.5a8.48 8.48 0 0 1 8 8v.5Z"/>`,
  menu: `<path d="M3 6h18M3 12h18M3 18h18"/>`,
  close: `<path d="M18 6 6 18M6 6l12 12"/>`,
  chevronDown: `<path d="m6 9 6 6 6-6"/>`,
  sparkle: `<path d="M12 3v4M12 17v4M3 12h4M17 12h4M6 6l2.5 2.5M15.5 15.5 18 18M18 6l-2.5 2.5M8.5 15.5 6 18"/>`,

  // ---- solid / social ----
  star: `<path d="M12 2.5l2.9 5.9 6.5.95-4.7 4.58 1.11 6.47L12 17.4l-5.81 3.05 1.11-6.47L2.6 9.35l6.5-.95Z" fill="currentColor" stroke="none"/>`,
  quote: `<path d="M9.5 7C6.46 7 4 9.46 4 12.5V19h6.5v-6.5H7.5C7.5 10.84 8.84 9.5 10.5 9.5V7H9.5Zm10 0c-3.04 0-5.5 2.46-5.5 5.5V19H20.5v-6.5h-3C17.5 10.84 18.84 9.5 20.5 9.5V7h-1Z" fill="currentColor" stroke="none"/>`,
  facebook: `<path d="M14 8.5h2.5V5h-2.5C11.79 5 10 6.79 10 9v2H8v3.5h2V21h3.5v-6.5H16l.5-3.5h-3V9c0-.28.22-.5.5-.5Z" fill="currentColor" stroke="none"/>`,
  instagram: `<rect x="3" y="3" width="18" height="18" rx="5"/><circle cx="12" cy="12" r="4"/><path d="M17.5 6.5h.01"/>`,
  youtube: `<path d="M21.5 8.2a2.5 2.5 0 0 0-1.76-1.77C18.2 6 12 6 12 6s-6.2 0-7.74.43A2.5 2.5 0 0 0 2.5 8.2 26 26 0 0 0 2.25 12a26 26 0 0 0 .25 3.8 2.5 2.5 0 0 0 1.76 1.77C5.8 18 12 18 12 18s6.2 0 7.74-.43a2.5 2.5 0 0 0 1.76-1.77A26 26 0 0 0 21.75 12a26 26 0 0 0-.25-3.8Z"/><path d="m10 9 5 3-5 3Z" fill="currentColor" stroke="none"/>`,
  linkedin: `<path d="M16 8a6 6 0 0 1 6 6v6h-4v-6a2 2 0 0 0-4 0v6h-4v-9h4v1.5A4 4 0 0 1 16 8Z"/><rect x="2" y="9" width="4" height="11"/><circle cx="4" cy="4" r="2"/>`,
};

const inner = icons[name] ?? "";
const isSolidStar = name === "star" || name === "quote";
---
<svg
  viewBox="0 0 24 24"
  class={className}
  fill={isSolidStar ? "currentColor" : "none"}
  stroke="currentColor"
  stroke-width={strokeWidth}
  stroke-linecap="round"
  stroke-linejoin="round"
  aria-hidden="true"
  set:html={inner}
/>
