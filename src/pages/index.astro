---
import Layout from "../layouts/Layout.astro";
import Header from "../components/Header.astro";
import Hero from "../components/Hero.astro";
import Stats from "../components/Stats.astro";
import About from "../components/About.astro";
import Services from "../components/Services.astro";
import Journey from "../components/Journey.astro";
import WhyChooseUs from "../components/WhyChooseUs.astro";
import Doctors from "../components/Doctors.astro";
import Testimonials from "../components/Testimonials.astro";
import FAQ from "../components/FAQ.astro";
import Contact from "../components/Contact.astro";
import Footer from "../components/Footer.astro";
import FloatingContact from "../components/FloatingContact.astro";
---

<Layout>
  <Header />
  <main id="main">
    <Hero />
    <Stats />
    <About />
    <Services />
    <Journey />
    <WhyChooseUs />
    <Doctors />
    <Testimonials />
    <FAQ />
    <Contact />
  </main>
  <Footer />
  <FloatingContact />
</Layout>
